{
  "Serilog": {
    "using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq", "Serilog.Sinks.MSSqlServer", "Serilog.Enrichers.ClientInfo" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": { "Microsoft" : "Information"}
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithClientIp" ],
    "WriteTo": [
      {
        "Name": "Console"
      },
    ]
  }
}
